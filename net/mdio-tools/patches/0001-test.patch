From 5b0f951ae6f7177e92977cf632841c9446374158 Mon Sep 17 00:00:00 2001
From: Aleksander Jan Bajkowski <olek2@wp.pl>
Date: Sun, 28 Sep 2025 23:31:00 +0200
Subject: [PATCH] test

$ mdio mt7530-0 0x05:31 dump 0x0+512
Segmentation fault

Signed-off-by: Aleksander Jan Bajkowski <olek2@wp.pl>
---
 src/mdio/mdio.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/src/mdio/mdio.c b/src/mdio/mdio.c
index 4677db6..fc0791e 100644
--- a/src/mdio/mdio.c
+++ b/src/mdio/mdio.c
@@ -618,9 +618,13 @@ int mdio_xfer_timeout(const char *bus, struct mdio_prog *prog,
 		return -ENOMEM;
 
 	mnl_attr_put_strz(nlh, MDIO_NLA_BUS_ID, bus);
+	printf("%s:3 len=%ld, len=%d, size=%ld\n", __func__, len, prog->len, sizeof(*prog->insns));
+	if (prog->len * sizeof(*prog->insns) > len)
+		return -ENOMEM;
 	mnl_attr_put(nlh, MDIO_NLA_PROG, prog->len * sizeof(*prog->insns),
 		     prog->insns);
 
+	printf("%s:4\n", __func__);
 	mnl_attr_put_u16(nlh, MDIO_NLA_TIMEOUT, timeout_ms);
 
 	err = msg_query(nlh, mdio_xfer_cb, &xfer);
-- 
2.47.3

